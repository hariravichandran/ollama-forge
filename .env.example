# ollama-forge configuration
# Copy to .env and edit as needed: cp .env.example .env

# Ollama server URL (default: http://localhost:11434)
# OLLAMA_BASE_URL=http://localhost:11434

# Default model (auto-detected from hardware if not set)
# FORGE_DEFAULT_MODEL=qwen2.5-coder:7b

# ROCm settings (auto-detected, override if needed)
# HSA_OVERRIDE_GFX_VERSION=10.3.0
# OLLAMA_FLASH_ATTENTION=1
# OLLAMA_MAX_LOADED_MODELS=2

# Web search (enabled by default, set to 0 to disable)
# FORGE_WEB_SEARCH=1

# Web UI port
# FORGE_WEB_PORT=8080

# Log level (DEBUG, INFO, WARNING, ERROR)
# FORGE_LOG_LEVEL=INFO

# Community ideas collection (enabled by default, no GitHub CLI needed)
# Ideas are collected anonymously and help improve ollama-forge.
# Set to 0 to opt out of idea collection.
# FORGE_COMMUNITY_IDEAS=1

# Self-improvement agent (DISABLED by default — opt-in only)
# Set to 1 to enable the self-improvement agent. This uses spare CPU/GPU
# resources to improve ollama-forge. Improvements are submitted as GitHub PRs.
# Requires `gh` CLI: https://cli.github.com/
# FORGE_SELF_IMPROVE=0

# Maintainer mode for self-improvement (direct push instead of PRs)
# Only for repo maintainers with direct push access.
# FORGE_SELF_IMPROVE_MAINTAINER=0
